# Telegram Bot Token (from BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID to receive alerts (can be group or individual ID)
CHAT_ID=your_chat_id_here

# RPC URL for Base Network (optional, default provided in config)
# RPC_URL=https://mainnet.base.org

# Subgraph API Endpoints (optional, defaults provided in config)
# PANCAKE_V3_SUBGRAPH=https://api.studio.thegraph.com/query/45376/exchange-v3-base/version/latest
# UNISWAP_V3_SUBGRAPH=https://api.studio.thegraph.com/query/48080/uniswap-v3-base/version/latest

# Target wallet address to automatically track its LP NFTs
# WALLET_ADDRESS=0xYourWalletAddressHere

# Cloudflare R2 Backup
# 若未設定，BackupCron 會 warn 並略過，不影響 bot 主流程
#
# 兩組 bucket + token（Decision #12，2026-04-11 updated）：
#   - Prod：bucket=tradingbot-backup，token=dexbot-backup-prod-token
#   - Dev  ：bucket=tradingbot-backup-dev，token=dexbot-backup-dev-token
#
# 本地 .env 建議填 dev 那組（避免開發時污染 prod 資料）；
# Railway env vars 填 prod 那組。R2_BUCKET 留空 = fallback 到 prod 名稱。
#
# 備註：R2_API_TOKEN 程式碼不會讀，只是方便 rotate 時有個地方查。
# 真正被 S3 SDK 使用的是 R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY。
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=tradingbot-backup-dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_API_TOKEN=                                   # reference only, not read by code
